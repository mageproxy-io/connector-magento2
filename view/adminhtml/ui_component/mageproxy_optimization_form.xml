                        <dataScope>mageproxy_dependency_listing_modal_remove</dataScope>
                        <ns>mageproxy_dependency_listing_modal_remove</ns>
                        <realTimeLink>true</realTimeLink>
                        <externalProvider>${ $.ns }.mageproxy_dependency_listing_modal_remove_data_source</externalProvider>
