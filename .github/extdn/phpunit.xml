<?xml version="1.0" encoding="UTF-8"?>
<phpunit backupGlobals="false"
         backupStaticAttributes="false"
         beStrictAboutTestsThatDoNotTestAnything="false"
         beStrictAboutOutputDuringTests="false"
         colors="true"
         verbose="true"
         bootstrap="/var/www/magento2ce/dev/tests/integration/framework/bootstrap.php">

    <testsuites>
        <testsuite name="Mageproxy_Connector Integration">
            <!-- Prefer the mounted workspace to avoid packaging filters -->
            <directory suffix="Test.php">/github/workspace/Test/Integration</directory>
            <!-- Try vendor path -->
            <directory suffix="Test.php">/var/www/magento2ce/vendor/mageproxy/connector-magento2/Test/Integration</directory>
            <!-- Fallback to app/code install path -->
            <directory suffix="Test.php">/var/www/magento2ce/app/code/Mageproxy/Connector/Test/Integration</directory>
        </testsuite>
    </testsuites>

    <php>
        <ini name="display_errors" value="1"/>
        <ini name="display_startup_errors" value="1"/>
        <ini name="memory_limit" value="-1"/>
        <ini name="date.timezone" value="UTC"/>
        <const name="TESTS_INSTALL_CONFIG_FILE" value="/var/www/magento2ce/dev/tests/integration/etc/install-config-mysql.php"/>
        <const name="TESTS_POST_INSTALL_SETUP_COMMAND_CONFIG_FILE" value="/var/www/magento2ce/dev/tests/integration/etc/post-install-setup-command-config.php"/>
        <const name="TESTS_GLOBAL_CONFIG_FILE" value="/var/www/magento2ce/dev/tests/integration/etc/config-global.php"/>
        <const name="TESTS_GLOBAL_CONFIG_DIR" value="/var/www/magento2ce/app/etc"/>
        <const name="TESTS_CLEANUP" value="enabled"/>
        <const name="USE_OVERRIDE_CONFIG" value="enabled"/>
    </php>
</phpunit>
