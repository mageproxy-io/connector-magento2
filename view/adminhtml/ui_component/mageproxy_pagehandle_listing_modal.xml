<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageproxy_pagehandle_listing_modal.mageproxy_pagehandle_listing_modal_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>mageproxy_pagehandle_listing_modal_columns</spinner>
        <deps>
            <dep>mageproxy_pagehandle_listing_modal.mageproxy_pagehandle_listing_modal_data_source</dep>
        </deps>
        <buttons/>
    </settings>
    <dataSource name="mageproxy_pagehandle_listing_modal_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">page_handle</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="mageproxy_pagehandle_listing_modal_data_source">
            <settings>
                <requestFieldName>page_handle</requestFieldName>
                <primaryFieldName>page_handle</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="sticky" xsi:type="boolean">false</item>
            </item>
        </argument>
        <filters name="listing_filters"/>
        <paging name="listing_paging" />
    </listingToolbar>
    <columns name="mageproxy_pagehandle_listing_modal_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>page_handle</indexField>
                <preserveSelectionsOnFilter>true</preserveSelectionsOnFilter>
            </settings>
        </selectionsColumn>
        <column name="page_handle" sortOrder="10">
            <settings>
                <filter>text</filter>
                <label translate="true">Page Handle</label>
                <dataScope>page_handle</dataScope>
                <dataType>text</dataType>
            </settings>
        </column>
    </columns>
</listing>
