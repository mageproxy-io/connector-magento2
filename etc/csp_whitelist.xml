<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="mageproxy-io" type="host">*.mageproxy.io</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="mageproxy-io" type="host">*.mageproxy.io</value>
            </values>
        </policy>
        <!-- Allow inline-created Web Workers via blob: URL -->
        <policy id="worker-src">
            <values>
                <value id="blob-scheme" type="scheme">blob:</value>
            </values>
        </policy>
        <!-- Fallback for older UAs that gate workers under child-src -->
        <policy id="child-src">
            <values>
                <value id="blob-scheme" type="scheme">blob:</value>
            </values>
        </policy>
        <!-- Allow fetch() from the recorder endpoint domain -->
        <policy id="connect-src">
            <values>
                <value id="mageproxy-io" type="host">*.mageproxy.io</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
