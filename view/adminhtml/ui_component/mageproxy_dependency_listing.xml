<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageproxy_dependency_listing.mageproxy_dependency_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>mageproxy_dependency_listing_columns</spinner>
        <deps>
            <dep>mageproxy_dependency_listing.mageproxy_dependency_listing_data_source</dep>
        </deps>
        <buttons/>
    </settings>
    <dataSource name="mageproxy_dependency_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">dependency_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="mageproxy_dependency_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>dependency_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="sticky" xsi:type="boolean">false</item>
            </item>
        </argument>
        <filters name="listing_filters"/>
        <paging name="listing_paging" />
    </listingToolbar>
    <columns name="mageproxy_dependency_listing_columns">
        <column name="recording_id" sortOrder="5">
            <settings>
                <label translate="true">recording</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="module_id" sortOrder="10">
            <settings>
                <filter>text</filter>
                <label translate="true">RequireJS Module ID</label>
            </settings>
        </column>
        <column name="page_handle" sortOrder="20">
            <settings>
                <filter>select</filter>
                <options class="\Mageproxy\Connector\Ui\Component\Listing\Column\PageHandle"/>
                <dataType>select</dataType>
                <label translate="true">Page Handle</label>
            </settings>
        </column>
<!--        <column name="priority" sortOrder="30" class="\Mageproxy\Connector\Ui\Component\Listing\Column\PageHandlePriority">-->
        <column name="priority" sortOrder="30">
            <settings>
                <label translate="true">Priority</label>
                <filter>text</filter>
            </settings>
        </column>
    </columns>
</listing>
