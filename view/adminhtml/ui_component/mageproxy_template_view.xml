<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" component="Magento_Customer/js/form/components/form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageproxy_template_view.mageproxy_template_view_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="delete" class="Mageproxy\Connector\Block\Adminhtml\OptimizationTemplateDeleteButton"/>
            <button name="back" class="Mageproxy\Connector\Block\Adminhtml\BackButton"/>
        </buttons>
        <namespace>mageproxy_template_view</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>mageproxy_template_view.mageproxy_template_view_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mageproxy_template_view_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <dataProvider class="Mageproxy\Connector\Ui\DataProvider\Form\TemplateDataProvider" name="mageproxy_template_view_data_source">
            <settings>
                <primaryFieldName>template_id</primaryFieldName>
                <requestFieldName>id</requestFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="0">
        <settings>
            <collapsible>true</collapsible>
            <opened>true</opened>
            <label translate="true">General</label>
        </settings>
        <field name="store" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Store</label>
                <dataScope>store</dataScope>
                <elementTmpl>ui/form/element/html</elementTmpl>
            </settings>
        </field>
        <field name="minify_js" formElement="input" component="Mageproxy_Connector/js/component/form/element/yesno-text" sortOrder="15">
            <settings>
                <label translate="true">Minify Js</label>
                <elementTmpl>ui/form/element/text</elementTmpl>
            </settings>
        </field>
        <field name="minify_html" formElement="input" component="Mageproxy_Connector/js/component/form/element/yesno-text" sortOrder="17">
            <settings>
                <label translate="true">Minify Html</label>
                <elementTmpl>ui/form/element/text</elementTmpl>
            </settings>
        </field>
        <field name="excluded_deps" formElement="input" sortOrder="20">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="title" xsi:type="string" translate="true">Module ID</item>
                </item>
            </argument>
            <settings>
                <label>Excluded Dependencies</label>
                <dataScope>exclude_deps</dataScope>
                <elementTmpl>Mageproxy_Connector/form/element/list</elementTmpl>
            </settings>
        </field>
        <field name="removed_deps" formElement="input" sortOrder="30">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="title" xsi:type="string" translate="true">Module ID</item>
                </item>
            </argument>
            <settings>
                <label>Removed Dependencies</label>
                <dataScope>remove_deps</dataScope>
                <elementTmpl>Mageproxy_Connector/form/element/list</elementTmpl>
            </settings>
        </field>
        <field name="page_handles" formElement="input" sortOrder="40">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="title" xsi:type="string" translate="true">Page Handle</item>
                </item>
            </argument>
            <settings>
                <label>Page Handle Priority</label>
                <dataScope>handles</dataScope>
                <elementTmpl>Mageproxy_Connector/form/element/list</elementTmpl>
            </settings>
        </field>
        <field name="browserslist_config" formElement="input" sortOrder="50">
            <settings>
                <label translate="true">Transpilation</label>
                <dataType>text</dataType>
                <elementTmpl>ui/form/element/text</elementTmpl>
            </settings>
        </field>
        <field name="transpile_globs" formElement="input" sortOrder="60">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="title" xsi:type="string" translate="true">Glob</item>
                </item>
            </argument>
            <settings>
                <dataScope>transpile_globs</dataScope>
                <elementTmpl>Mageproxy_Connector/form/element/list</elementTmpl>
            </settings>
        </field>
    </fieldset>
</form>
